// MCFMP-CMLMS - Muslim Christian Fisherfolks Multi-Purpose Cooperative
// Money Lending and Management System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  COLLECTOR
  CREDIT_COMMITTEE
  BOARD_OF_DIRECTORS
  TREASURER
  LOANS_CLERK
  DISBURSING_STAFF
  CASHIER
  MEMBER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum MemberStatus {
  ACTIVE
  INACTIVE
}

enum LoanType {
  MEMBERSHIP_LOAN
  MICRO_LOAN
  REGULAR_LOAN
  PRODUCTION_LOAN
  SHORT_TERM_LOAN
  LONG_TERM_LOAN
  EDUCATIONAL_LOAN
}

enum ApplicationStatus {
  PENDING
  CIBI_REVIEW
  MANAGER_REVIEW
  COMMITTEE_REVIEW
  BOARD_REVIEW
  APPROVED
  REJECTED
  FUNDED
  RELEASED
}

enum AmortizationType {
  MONTHLY
  DAILY
  LUMPSUM
}

enum ReleaseMethod {
  CASH
  CHEQUE
}

enum LoanStatus {
  ACTIVE
  PAID
  DELINQUENT
  RENEWED
}

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  name           String?
  passwordHash   String     @map("password_hash")
  role           Role       @default(MEMBER)
  status         UserStatus @default(ACTIVE)
  emailVerified  DateTime?  @map("email_verified")
  image          String?
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  accounts            Account[]
  sessions            Session[]
  member              Member?
  paymentsCollected   Payment[] @relation("CollectedBy")
  applicationsAssigned LoanApplication[] @relation("CollectorAssigned")
  applicationsCibiApproved LoanApplication[] @relation("CibiApprovedBy")
  applicationsManagerApproved LoanApplication[] @relation("ManagerApprovedBy")
  applicationsCommitteeBoardApproved LoanApplication[] @relation("CommitteeBoardApprovedBy")
  applicationsFunded LoanApplication[] @relation("FundedBy")
  documentsUploaded   Document[] @relation("UploadedBy")
  notifications       Notification[]
  activityLogs       ActivityLog[]
}

model Account {
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires     DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model Member {
  id              String       @id @default(cuid())
  memberNo        String       @unique @map("member_no")
  name            String
  address         String?      @db.Text
  contactNo       String?      @map("contact_no")
  religion        String?
  occupation      String?
  cbu             Float        @default(0) // Capital Build Up in PHP
  isRegularMember Boolean      @default(false) @map("is_regular_member")
  status          MemberStatus @default(ACTIVE) @map("status")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  userId          String?      @unique @map("user_id")

  user             User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  loanApplications LoanApplication[]
  loans            Loan[]
}

model LoanApplication {
  id              String            @id @default(cuid())
  applicationNo   String            @unique @map("application_no")
  loanType        LoanType          @map("loan_type")
  amount          Float
  termMonths      Int?              @map("term_months")
  termDays        Int?              @map("term_days")
  purpose         String?           @db.Text
  status          ApplicationStatus @default(PENDING)
  approvalLevel   String?           @map("approval_level") // MANAGER | COMMITTEE | BOARD
  // CI/BI 5C's fields
  characterNotes  String?           @map("character_notes") @db.Text
  capacityNotes   String?           @map("capacity_notes") @db.Text
  capitalNotes    String?           @map("capital_notes") @db.Text
  collateralNotes String?           @map("collateral_notes") @db.Text
  conditionsNotes String?           @map("conditions_notes") @db.Text
  cibiPassed      Boolean?          @map("cibi_passed")
  submittedAt     DateTime?         @map("submitted_at")
  approvedAt      DateTime?         @map("approved_at")
  rejectedAt      DateTime?         @map("rejected_at")
  rejectionReason String?           @map("rejection_reason") @db.Text
  approvalRemarks String?           @map("approval_remarks") @db.Text
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  memberId        String            @map("member_id")
  loanProductId   String?           @map("loan_product_id")
  collectorId     String?           @map("collector_id")
  cibiApprovedById     String?      @map("cibi_approved_by_id")
  managerApprovedById  String?      @map("manager_approved_by_id")
  committeeBoardApprovedById String? @map("committee_board_approved_by_id")
  fundedById         String?       @map("funded_by_id")

  member       Member      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  loanProduct  LoanProduct? @relation(fields: [loanProductId], references: [id], onDelete: SetNull)
  collector    User?       @relation("CollectorAssigned", fields: [collectorId], references: [id], onDelete: SetNull)
  cibiApprovedBy    User?   @relation("CibiApprovedBy", fields: [cibiApprovedById], references: [id], onDelete: SetNull)
  managerApprovedBy User?   @relation("ManagerApprovedBy", fields: [managerApprovedById], references: [id], onDelete: SetNull)
  committeeBoardApprovedBy User? @relation("CommitteeBoardApprovedBy", fields: [committeeBoardApprovedById], references: [id], onDelete: SetNull)
  fundedBy     User?       @relation("FundedBy", fields: [fundedById], references: [id], onDelete: SetNull)
  loan         Loan?
  documents    Document[]
}

model Loan {
  id                 String           @id @default(cuid())
  loanNo             String           @unique @map("loan_no")
  loanType           LoanType         @map("loan_type")
  principalAmount    Float            @map("principal_amount")
  interestRate       Float            @map("interest_rate") // per month or per term as per loan config
  termMonths         Int?             @map("term_months")
  termDays           Int?             @map("term_days")
  amortizationType   AmortizationType @map("amortization_type")
  outstandingBalance Float           @map("outstanding_balance")
  status             LoanStatus      @default(ACTIVE)
  releasedAt         DateTime?       @map("released_at")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  applicationId      String?         @unique @map("application_id")
  memberId           String          @map("member_id")

  application        LoanApplication?   @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  member             Member            @relation(fields: [memberId], references: [id], onDelete: Cascade)
  amortizationSchedule AmortizationSchedule[]
  payments           Payment[]
  voucher            LoanVoucher?
}

model AmortizationSchedule {
  id          String   @id @default(cuid())
  dueDate     DateTime @map("due_date")
  principal   Float
  interest    Float
  totalDue    Float    @map("total_due")
  penalty     Float    @default(0)
  paidAmount  Float    @default(0) @map("paid_amount")
  isPaid      Boolean  @default(false) @map("is_paid")
  paidAt      DateTime? @map("paid_at")
  sequence    Int      // 1, 2, 3... for ordering
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  loanId      String   @map("loan_id")

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)
  payments Payment[]
}

enum PaymentStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

model Payment {
  id              String        @id @default(cuid())
  amount          Float
  principal       Float         @default(0)
  interest        Float         @default(0)
  penalty         Float         @default(0)
  paymentDate     DateTime      @map("payment_date")
  paymentMethod   String?       @map("payment_method") // CASH, BPI, GCash, etc.
  status          PaymentStatus @default(APPROVED) @map("status")
  referenceNo     String?       @map("reference_no")
  remarks         String?       @db.Text
  createdAt       DateTime      @default(now()) @map("created_at")
  loanId          String        @map("loan_id")
  collectedById   String?       @map("collected_by_id")
  amortizationScheduleId String? @map("amortization_schedule_id")

  loan         Loan  @relation(fields: [loanId], references: [id], onDelete: Cascade)
  collectedBy  User? @relation("CollectedBy", fields: [collectedById], references: [id], onDelete: SetNull)
  receipt      Document? @relation("PaymentReceipt")
  amortizationSchedule AmortizationSchedule? @relation(fields: [amortizationScheduleId], references: [id], onDelete: SetNull)
}

model LoanVoucher {
  id           String        @id @default(cuid())
  voucherNo   String        @unique @map("voucher_no")
  releaseMethod ReleaseMethod @map("release_method")
  chequeNo     String?       @map("cheque_no")
  releasedAt   DateTime      @map("released_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  loanId       String        @unique @map("loan_id")

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)
}

model Requirement {
  id        String   @id @default(cuid())
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  loanProducts LoanProductRequirement[]
  documents    Document[]
}

model LoanProduct {
  id             String   @id @default(cuid())
  name           String
  termMonthsMin  Int?
  termMonthsMax  Int?
  termDaysMin    Int?
  termDaysMax    Int?
  maxCbuPercent  Float?   // e.g. 80 means 80% of CBU
  maxAmountFixed Float?   // fixed peso ceiling, optional
  amortization   String   // e.g. "Monthly", "Daily", "Lump sum"
  interestRate   Float    // e.g. 0.03 = 3% per month
  interestLabel  String   // e.g. "3% per month diminishing"
  penaltyRate    Float    // e.g. 0.02 = 2% per month
  penaltyLabel   String   // e.g. "2% per month based on amortization delayed"
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  loanApplications LoanApplication[]
  requirements     LoanProductRequirement[]
}

model LoanProductRequirement {
  loanProductId  String @map("loan_product_id")
  requirementId  String @map("requirement_id")

  loanProduct LoanProduct @relation(fields: [loanProductId], references: [id], onDelete: Cascade)
  requirement Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@id([loanProductId, requirementId])
}

model Document {
  id            String   @id @default(cuid())
  fileName      String   @map("file_name")
  fileUrl       String   @map("file_url")
  fileSize      Int?     @map("file_size")
  mimeType      String?   @map("mime_type")
  category      String   // REQUIREMENT | PHOTO | INVESTIGATION | PAYMENT_RECEIPT
  applicationId String?  @map("application_id")
  requirementId String?  @map("requirement_id")
  paymentId     String?  @unique @map("payment_id")
  uploadedById  String?  @map("uploaded_by_id")
  createdAt     DateTime @default(now()) @map("created_at")

  application  LoanApplication? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  requirement  Requirement?     @relation(fields: [requirementId], references: [id], onDelete: SetNull)
  uploadedBy   User?            @relation("UploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  payment      Payment?         @relation("PaymentReceipt", fields: [paymentId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  title     String
  message   String   @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  type      String   // LOAN_APPROVED | LOAN_REJECTED | CIBI_ASSIGNED
  link      String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id         String   @id @default(cuid())
  action     String   // e.g. LOGIN, USER_CREATED, LOAN_CREATED, PAYMENT_RECORDED
  entityType String?  @map("entity_type") // User, Member, Loan, Payment, etc.
  entityId   String?  @map("entity_id")
  details    String?  @db.Text // JSON or short description
  ip         String?
  userAgent  String?  @map("user_agent") @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  userId     String?  @map("user_id")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

enum PaymentMethodStatus {
  ACTIVE
  INACTIVE
}

model PaymentMethod {
  id             String              @id @default(cuid())
  accountName    String              @map("account_name")
  accountNumber  String              @map("account_number")
  type           String              @map("type") // e.g. BPI, GCash, Other
  status         PaymentMethodStatus @default(ACTIVE) @map("status")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
}
